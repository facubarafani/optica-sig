# --- Application ---
APP_NAME="SGI Optica"
ENVIRONMENT=local
DEBUG=true

# --- Database ---
# Used by the app and Alembic. Override in CI/prod.
DATABASE_URL=postgresql+psycopg2://sgi:sgi@localhost:5432/sgi

# --- Security ---
# Generate a strong value for production, e.g. `openssl rand -hex 32`
SECRET_KEY=change-me-in-production-please-0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# --- Single-tenant MVP ---
# The active company for single-tenant deployments. Multi-tenant ready: every
# row carries company_id, so this can be removed once tenant resolution lands.
DEFAULT_COMPANY_ID=1
