# SGI Óptica — production environment template.
# Copy to .env and fill in. NEVER commit the real .env (it holds secrets).
#
#   cp .env.prod.example .env

# --- Security (REQUIRED) ---
# Generate a strong value:  openssl rand -hex 32
SECRET_KEY=CHANGE-ME-openssl-rand-hex-32

# --- Self-hosted Postgres (docker-compose.prod.yml path) ---
# DATABASE_URL is built automatically from these by the compose file.
POSTGRES_USER=sgi
POSTGRES_PASSWORD=CHANGE-ME-strong-password
POSTGRES_DB=sgi

# --- Public domain for automatic HTTPS (compose/Caddy path) ---
# Point this domain's DNS A record at the server's public IP first.
APP_DOMAIN=demo.tudominio.com

# --- App config ---
ACCESS_TOKEN_EXPIRE_MINUTES=480
DEFAULT_COMPANY_ID=1
WEB_CONCURRENCY=2

# Seed demo data on first boot only. Set true for the very first deploy,
# then change to false so subsequent deploys don't re-run the seed.
SEED_ON_START=true

# --- Using Coolify-managed Postgres or Neon instead of the compose DB? ---
# Then ignore POSTGRES_*/APP_DOMAIN above and set DATABASE_URL directly:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
